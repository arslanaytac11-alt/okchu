{
  "appId": "com.arslanaytac.okchu",
  "appName": "Okchu",
  "webDir": "www",
  "server": {
    "iosScheme": "okchu",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false,
    "backgroundColor": "#f0e4c8"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#f0e4c8",
      "showSpinner": false,
      "splashImmersive": true,
      "splashFullScreen": true
    }
  }
}
